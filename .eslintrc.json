{
  "extends": "next/core-web-vitals",
  "plugins": ["max-lines"],
  "rules": {
    "max-lines": [
      "warn",
      { "max": 200, "skipBlankLines": true, "skipComments": true }
    ],
    "max-lines-per-function": [
      "error",
      { "max": 50, "skipBlankLines": true, "skipComments": true }
    ]
  }
}
