# GitHub (required for auto-PR)
GITHUB_TOKEN=

# Supabase
# IMPORTANT: JWT_SECRET must match the Supabase dashboard JWT Secret setting
# (Settings > API > JWT Secret) for auth.uid() to resolve in RLS policies.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Teller.io bank connection
TELLER_APP_ID=
TELLER_SIGNING_SECRET=

# AI categorization
ANTHROPIC_API_KEY=

# Authentication
# JWT_SECRET: used for JWT signing AND HMAC-signing WebAuthn challenge cookies.
# Must be ≥ 32 characters. Must match Supabase dashboard JWT Secret.
JWT_SECRET=

# Teller token encryption key — separate from JWT_SECRET to isolate key domains.
# Generate with: openssl rand -hex 32
TELLER_ENCRYPTION_KEY=

# WebAuthn — MUST be set to the deployment domain in production.
# Leaving these unset uses localhost defaults, causing assertion failures in prod.
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGIN=
